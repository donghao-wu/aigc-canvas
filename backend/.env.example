# ── 必填 ──────────────────────────────────────────────────────
# DashScope API Key (阿里云百炼平台，用于 Qwen LLM + Wanx 生图 + WAN 视频)
# 获取地址：https://bailian.console.aliyun.com/ → API Key 管理
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT 签名密钥（任意随机字符串，生产环境请用 openssl rand -base64 32 生成）
JWT_SECRET=your-jwt-secret-change-in-production

# 管理员操作密钥（创建用户接口的验证头 x-admin-secret）
ADMIN_SECRET=your-admin-secret-change-in-production

# ── 存储（本地测试时留空或填 local）──────────────────────────
# local = 图片存本地 backend/generated/（开发用）
# oss   = 图片上传到阿里云 OSS（生产必须，视频文件更大）
STORAGE_DRIVER=local

# OSS 配置（STORAGE_DRIVER=oss 时必填）
# OSS_REGION=oss-cn-beijing
# OSS_BUCKET=your-bucket-name
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS_BASE_URL=https://your-cdn-domain.com  # 可选，自定义 CDN 域名

# ── 服务配置 ──────────────────────────────────────────────────
PORT=3001

# 允许的前端来源（逗号分隔，生产填实际域名）
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# SQLite 数据库路径（默认 backend/data/aigc.db，一般不需要改）
# DB_PATH=/var/data/aigc.db
